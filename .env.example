# ─── E-Signature Provider ────────────────────────────
# "none"     → disabled (send intake docs manually)
# "openapi"  → OpenAPI EU-SES (€0.49/signer + €0.15 timestamp, EU data on Google Cloud)
# "docusign" → DocuSign ($600/yr Developer plan required for API access)
ESIGN_PROVIDER=none

# ─── Site ─────────────────────────────────────────────
SITE_URL=https://robertrozek.de

# ─── Cal.com Webhook ──────────────────────────────────
# Create at: Cal.com → Settings → Developer → Webhooks
# Event: BOOKING_CREATED
CALCOM_WEBHOOK_SECRET=your-webhook-secret

# ─── OpenAPI (EU-SES) ────────────────────────────────
# Sign up at: console.openapi.com
# API docs: https://console.openapi.com/oas/de/esignature.openapi.json
# Pricing: €0.49/signer + €0.15/timestamp (pay-per-use)
# Sandbox: https://test.esignature.openapi.com
# Production: https://esignature.openapi.com
OPENAPI_API_KEY=your-openapi-key
OPENAPI_CALLBACK_URL=https://robertrozek.de/api/esign-callback
# OPENAPI_SANDBOX=true  ← uncomment for sandbox testing only

# ─── DocuSign ─────────────────────────────────────────
# Sign up at: developers.docusign.com
# For EU: use account-d.docusign.com (demo) or account.docusign.com (prod)
# Base URL EU: https://demo.docusign.net/restapi (demo) or https://eu.docusign.net/restapi (prod)
# Base URL US: https://demo.docusign.net/restapi (demo) or https://na4.docusign.net/restapi (prod)
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_USER_ID=your-user-guid
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_PRIVATE_KEY=base64-encoded-rsa-private-key
